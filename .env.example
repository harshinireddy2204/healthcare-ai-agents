# ── Prefect (orchestration) ──────────────────────────────────
PREFECT_API_URL=

# ── App config ───────────────────────────────────────────────
MODEL_NAME=gpt-4o
CONFIDENCE_THRESHOLD=0.75
DATABASE_URL=sqlite:///./healthcare_agents.db
LOG_LEVEL=INFO
